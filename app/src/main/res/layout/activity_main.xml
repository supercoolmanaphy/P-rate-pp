<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Animated background host — views are added here programmatically -->
    <FrameLayout
        android:id="@+id/fl_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Translucent scrim so UI text stays legible over animations -->
    <View
        android:id="@+id/v_bg_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="160dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── APP HEADER ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:paddingTop="40dp"
                android:paddingBottom="8dp">

                <!-- Title + version stacked -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P-RATE++"
                        android:fontFamily="monospace"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/neon_cyan"
                        android:shadowColor="@color/neon_cyan"
                        android:shadowRadius="12"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tv_app_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MUSIC PLAYER v1.0"
                        android:fontFamily="monospace"
                        android:textSize="10sp"
                        android:textColor="@color/neon_green"
                        android:shadowColor="@color/neon_green"
                        android:shadowRadius="4"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:letterSpacing="0.15"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- EQ button -->
                <ImageButton
                    android:id="@+id/btn_eq"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_eq"
                    android:background="@drawable/bg_icon_button"
                    android:tint="@color/neon_cyan"
                    android:contentDescription="@string/open_equalizer"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="8dp" />

                <!-- Background theme picker button -->
                <ImageButton
                    android:id="@+id/btn_theme_picker"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_themes"
                    android:background="@drawable/bg_icon_button"
                    android:tint="@color/neon_cyan"
                    android:contentDescription="Choose background theme"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="8dp" />

                <!-- Color-picker button -->
                <ImageButton
                    android:id="@+id/btn_color_picker"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_palette"
                    android:background="@drawable/bg_icon_button"
                    android:tint="@color/neon_cyan"
                    android:contentDescription="Choose accent color"
                    android:padding="8dp"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/divider_neon"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <!-- ── RECENT DOWNLOADS ────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

                <TextView
                    android:id="@+id/tv_section_recent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◈ RECENT DOWNLOADS"
                    style="@style/Y2kSectionHeader"
                    android:layout_marginBottom="10dp" />

                <ProgressBar
                    android:id="@+id/progress_loading_recent_songs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/neon_cyan"
                    android:visibility="gone"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:id="@+id/tv_no_songs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_songs"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_recent_songs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>

            <!-- ── PLAYLISTS ───────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp">

                <!-- Section header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tv_section_playlists"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="◈ PLAYLISTS"
                        style="@style/Y2kSectionHeader" />

                    <Button
                        android:id="@+id/btn_create_playlist"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="+ NEW"
                        style="@style/Y2kNeonButton" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_no_playlists"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_playlists"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_playlists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── NOW PLAYING BAR (bottom) ───────────────────────── -->
    <LinearLayout
        android:id="@+id/now_playing_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_player_panel"
        android:visibility="gone"
        app:layout_anchor="@id/scroll_content"
        app:layout_anchorGravity="bottom"
        android:layout_gravity="bottom"
        android:elevation="8dp">

        <!-- Song info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/iv_now_playing_art"
                android:layout_width="@dimen/album_art_now_playing"
                android:layout_height="@dimen/album_art_now_playing"
                android:background="@drawable/bg_album_art"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_now_playing_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    style="@style/Y2kNowPlayingTitle" />

                <TextView
                    android:id="@+id/tv_now_playing_artist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    style="@style/Y2kArtistText" />

            </LinearLayout>

            <!-- Control buttons -->
            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="@dimen/control_btn_size"
                android:layout_height="@dimen/control_btn_size"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_prev"
                android:contentDescription="Previous"
                android:tint="@color/neon_cyan"
                android:scaleType="centerInside"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="@dimen/play_btn_size"
                android:layout_height="@dimen/play_btn_size"
                android:background="@drawable/bg_play_button"
                android:src="@drawable/ic_play"
                android:contentDescription="Play / Pause"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="@dimen/control_btn_size"
                android:layout_height="@dimen/control_btn_size"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_next"
                android:contentDescription="Next"
                android:tint="@color/neon_cyan"
                android:scaleType="centerInside"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Seek bar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="38dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:gravity="end" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressDrawable="@drawable/bg_seekbar"
                android:thumb="@drawable/bg_seekbar_thumb"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="38dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>
