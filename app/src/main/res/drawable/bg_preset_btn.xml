<?xml version="1.0" encoding="utf-8"?>
<!-- Preset button — active / selected state -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#001E28" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#00E5FF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0A2A30" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#00E5FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#05050F" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#1E1E3A" />
        </shape>
    </item>
</selector>
