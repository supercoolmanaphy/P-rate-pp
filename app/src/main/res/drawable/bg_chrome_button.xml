<?xml version="1.0" encoding="utf-8"?>
<!-- Chrome / metallic gradient button -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#505060"
                android:centerColor="#2A2A38"
                android:endColor="#101018"
                android:angle="270" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#00E5FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#D0D0E0"
                android:centerColor="#808090"
                android:endColor="#303040"
                android:angle="270" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#606070" />
        </shape>
    </item>
</selector>
