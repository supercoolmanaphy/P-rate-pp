<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Praticpp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_cyan_dim</item>
        <item name="colorSecondary">@color/neon_magenta</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="toolbarStyle">@style/Y2kToolbar</item>
    </style>

    <style name="Y2kToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg_dark</item>
        <item name="titleTextColor">@color/neon_cyan</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
    </style>

    <!-- Y2K dialog style -->
    <style name="Y2kDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="android:textColorPrimary">@color/neon_cyan</item>
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorAccent">@color/neon_cyan</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="buttonBarPositiveButtonStyle">@style/Y2kDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Y2kDialogButtonNeg</item>
    </style>

    <style name="Y2kDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Y2kDialogButtonNeg" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Section header text -->
    <style name="Y2kSectionHeader">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:shadowColor">@color/neon_cyan</item>
        <item name="android:shadowRadius">6</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
    </style>

    <!-- Song title text -->
    <style name="Y2kSongTitle">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:shadowColor">@color/neon_cyan</item>
        <item name="android:shadowRadius">4</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Artist / secondary text -->
    <style name="Y2kArtistText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Now-playing title -->
    <style name="Y2kNowPlayingTitle">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:shadowColor">@color/neon_cyan</item>
        <item name="android:shadowRadius">8</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">marquee</item>
        <item name="android:marqueeRepeatLimit">marquee_forever</item>
        <item name="android:singleLine">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:scrollHorizontally">true</item>
    </style>

    <!-- Chrome button -->
    <style name="Y2kChromeButton">
        <item name="android:background">@drawable/bg_chrome_button</item>
        <item name="android:textColor">@color/text_on_chrome</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Neon outlined button -->
    <style name="Y2kNeonButton">
        <item name="android:background">@drawable/bg_neon_button</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:shadowColor">@color/neon_cyan</item>
        <item name="android:shadowRadius">6</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

</resources>
